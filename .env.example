POLLINATIONS_API_KEY=sk_your_secret_key_here
# Có thể đặt nhiều endpoint, ngăn cách bằng dấu phẩy.
# Endpoint đầu tiên là ưu tiên cao nhất; nếu fail vì Cloudflare sẽ tự xoay vòng.
POLLINATIONS_ENDPOINTS=https://relay.YOUR-DOMAIN.workers.dev/v1/chat/completions,https://gen.pollinations.ai/v1/chat/completions,https://text.pollinations.ai/openai
DEFAULT_MODEL=gpt-5.4-nano
REQUEST_TIMEOUT_SECONDS=90
